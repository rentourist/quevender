<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MercadoIQ v3 — Tucumán</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root{
  --bg:#0b0e16;--bg2:#10131c;--bg3:#161a26;--surface:#1c2030;--surface2:#222840;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#eaecf4;--muted:#6b7191;
  --fb:#1877f2;--ml:#ffe600;--ig:#e1306c;
  --green:#4ade80;--cyan:#22d3ee;--amber:#fbbf24;--red:#f87171;--purple:#a78bfa;--pink:#f472b6;--orange:#fb923c;
  --font-d:'Syne',sans-serif;--font-b:'Inter',sans-serif;--font-m:'DM Mono',monospace;
  --r:10px;--r2:16px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--font-b);font-size:14px;min-height:100vh;overflow-x:hidden;}
.app{display:grid;grid-template-columns:240px 1fr;min-height:100vh;}
.sidebar{background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;}
.main{overflow-y:auto;min-width:0;}

/* SIDEBAR */
.logo{padding:18px 16px 14px;border-bottom:1px solid var(--border);}
.logo-name{font-family:var(--font-d);font-weight:800;font-size:20px;letter-spacing:-.5px;background:linear-gradient(120deg,var(--fb),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.logo-sub{font-size:9px;color:var(--muted);font-family:var(--font-m);letter-spacing:1.5px;margin-top:2px;}
.logo-v{font-size:9px;color:var(--green);font-family:var(--font-m);margin-top:4px;}
.nav{padding:8px 0;flex:1;}
.nav-section{padding:10px 14px 3px;font-size:9px;color:var(--muted);font-family:var(--font-m);letter-spacing:1.8px;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 14px;cursor:pointer;border-left:2px solid transparent;color:var(--muted);font-size:12px;transition:all .15s;user-select:none;}
.nav-item:hover{color:var(--text);background:rgba(255,255,255,.025);}
.nav-item.active{color:var(--fb);border-left-color:var(--fb);background:rgba(24,119,242,.07);font-weight:500;}
.nav-badge{margin-left:auto;font-size:9px;font-family:var(--font-m);background:rgba(74,222,128,.15);color:var(--green);padding:1px 5px;border-radius:3px;}
.nav-badge.live{background:rgba(248,113,113,.15);color:var(--red);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

/* TICKER */
.ticker-outer{background:var(--bg2);border-bottom:1px solid var(--border);padding:6px 0;overflow:hidden;}
.ticker-track{display:flex;gap:28px;animation:ticker 35s linear infinite;width:max-content;}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.tick{display:flex;align-items:center;gap:8px;white-space:nowrap;padding:0 14px;font-family:var(--font-m);font-size:11px;}
.tick-up{color:var(--green);}
.tick-down{color:var(--red);}
.tick-cat{font-size:9px;padding:1px 5px;border-radius:3px;font-weight:500;}

/* VIEWS */
.page-header{padding:20px 26px 0;display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;}
.page-title{font-family:var(--font-d);font-size:21px;font-weight:700;letter-spacing:-.3px;}
.page-sub{color:var(--muted);font-size:12px;margin-top:3px;}
.view{display:none;padding:0 26px 36px;}
.view.active{display:block;}

/* CARDS */
.metrics-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:18px;}
.mc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px;position:relative;overflow:hidden;}
.mc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.mc.c-fb::before{background:var(--fb);}
.mc.c-green::before{background:var(--green);}
.mc.c-amber::before{background:var(--amber);}
.mc.c-purple::before{background:var(--purple);}
.mc.c-cyan::before{background:var(--cyan);}
.mc.c-red::before{background:var(--red);}
.mc-label{font-size:9px;color:var(--muted);font-family:var(--font-m);text-transform:uppercase;letter-spacing:1px;}
.mc-value{font-family:var(--font-d);font-size:22px;font-weight:700;margin-top:5px;line-height:1;}
.mc-delta{font-size:11px;margin-top:4px;}
.tc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;margin-top:18px;}
.tc-head{padding:13px 18px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);gap:10px;flex-wrap:wrap;}
.tc-title{font-family:var(--font-d);font-weight:600;font-size:14px;}
table{width:100%;border-collapse:collapse;}
thead th{padding:8px 13px;text-align:left;font-size:9px;color:var(--muted);font-family:var(--font-m);text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(--border);font-weight:400;white-space:nowrap;}
tbody tr{cursor:pointer;transition:background .1s;}
tbody tr:hover{background:rgba(255,255,255,.025);}
tbody td{padding:10px 13px;font-size:13px;border-bottom:1px solid var(--border);vertical-align:middle;}
tbody tr:last-child td{border-bottom:none;}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:4px;font-size:10px;font-family:var(--font-m);font-weight:500;white-space:nowrap;}
.b-green{background:rgba(74,222,128,.12);color:var(--green);}
.b-amber{background:rgba(251,191,36,.12);color:var(--amber);}
.b-red{background:rgba(248,113,113,.12);color:var(--red);}
.b-blue{background:rgba(24,119,242,.15);color:var(--fb);}
.b-purple{background:rgba(167,139,250,.12);color:var(--purple);}
.b-pink{background:rgba(244,114,182,.12);color:var(--pink);}
.b-cyan{background:rgba(34,211,238,.12);color:var(--cyan);}
.b-orange{background:rgba(251,146,60,.12);color:var(--orange);}
.b-ml{background:rgba(255,230,0,.12);color:#e0c800;}
.b-ig{background:rgba(225,48,108,.12);color:var(--ig);}

/* CANAL BADGES */
.canal-tag{display:inline-flex;align-items:center;gap:3px;padding:2px 6px;border-radius:4px;font-size:9px;font-family:var(--font-m);font-weight:600;}
.c-fb-tag{background:rgba(24,119,242,.18);color:var(--fb);}
.c-ml-tag{background:rgba(255,230,0,.15);color:#c8aa00;}
.c-ig-tag{background:rgba(225,48,108,.15);color:var(--ig);}

/* MODO BADGE */
.modo-tag{display:inline-flex;align-items:center;padding:2px 6px;border-radius:4px;font-size:9px;font-family:var(--font-m);}
.m-com{background:rgba(74,222,128,.1);color:var(--green);}
.m-rev{background:rgba(34,211,238,.1);color:var(--cyan);}
.m-drop{background:rgba(167,139,250,.1);color:var(--purple);}
.m-int{background:rgba(251,191,36,.1);color:var(--amber);}

/* DBAR */
.dbar{display:flex;align-items:center;gap:6px;}
.dbar-bg{height:4px;background:var(--bg3);border-radius:3px;flex:1;min-width:50px;}
.dbar-fill{height:4px;border-radius:3px;}

/* CHARTS */
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:18px;}
.chart-grid3{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-top:18px;}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:18px;}
.chart-title{font-family:var(--font-d);font-weight:600;font-size:13px;margin-bottom:12px;}
.ch200{position:relative;height:200px;}
.ch260{position:relative;height:260px;}

/* HEATMAP */
.hm-wrap{overflow-x:auto;padding:14px 18px 18px;}
.hm-table{border-collapse:collapse;}
.hm-cat-lbl{font-size:10px;color:var(--muted);padding-right:11px!important;white-space:nowrap;font-family:var(--font-m);vertical-align:middle;}
.hm-month{font-size:9px;color:var(--muted);text-align:center;padding:0 2px 5px!important;font-family:var(--font-m);}
.hm-cell{width:44px;height:32px;text-align:center;vertical-align:middle;font-size:10px;font-family:var(--font-m);font-weight:500;border-radius:4px;cursor:default;transition:transform .1s;}
.hm-cell:hover{transform:scale(1.08);}

/* CAT TABS */
.cat-tabs{display:flex;gap:7px;margin-top:14px;flex-wrap:wrap;}
.ct{padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer;border:1px solid var(--border2);color:var(--muted);transition:all .15s;background:transparent;}
.ct:hover{color:var(--text);}
.ct.ae{background:rgba(34,211,238,.1);border-color:rgba(34,211,238,.35);color:var(--cyan);}
.ct.ar{background:rgba(244,114,182,.1);border-color:rgba(244,114,182,.35);color:var(--pink);}
.ct.ah{background:rgba(251,191,36,.1);border-color:rgba(251,191,36,.35);color:var(--amber);}
.ct.aj{background:rgba(167,139,250,.1);border-color:rgba(167,139,250,.35);color:var(--purple);}
.ct.am{background:rgba(34,211,238,.1);border-color:rgba(34,211,238,.35);color:var(--cyan);}
.ct.amq{background:rgba(251,146,60,.1);border-color:rgba(251,146,60,.35);color:var(--orange);}
.ct.ai{background:rgba(74,222,128,.1);border-color:rgba(74,222,128,.3);color:var(--green);}
.ct.aa{background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.15);color:var(--text);}

/* CALCULADORA */
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.field-group{display:flex;flex-direction:column;gap:5px;}
.field-label{font-size:9px;color:var(--muted);font-family:var(--font-m);text-transform:uppercase;letter-spacing:1px;}
.field-input,.field-select{background:var(--bg3);border:1px solid var(--border2);border-radius:8px;padding:8px 12px;color:var(--text);font-family:var(--font-m);font-size:13px;outline:none;width:100%;transition:border-color .15s;}
.field-input:focus,.field-select:focus{border-color:var(--fb);}
.field-select option{background:var(--bg2);}
.result-box{background:rgba(24,119,242,.06);border:1px solid rgba(24,119,242,.2);border-radius:var(--r);padding:16px;margin-top:12px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.ri label{font-size:9px;color:var(--muted);font-family:var(--font-m);text-transform:uppercase;letter-spacing:1px;display:block;}
.ri .val{font-family:var(--font-d);font-size:20px;font-weight:700;margin-top:3px;}
.stat-pair{display:flex;justify-content:space-between;font-size:12px;padding:6px 0;border-bottom:1px solid var(--border);}
.stat-pair:last-child{border-bottom:none;}
.sp-lbl{color:var(--muted);}
.sp-val{font-family:var(--font-m);font-weight:500;}
.strat-box{border-radius:var(--r);padding:11px 14px;font-size:12px;line-height:1.7;margin-top:10px;}

/* AI CHAT */
.ai-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;margin-top:18px;}
.ai-msgs{padding:14px;min-height:160px;max-height:360px;overflow-y:auto;display:flex;flex-direction:column;gap:11px;}
.msg{padding:9px 13px;border-radius:8px;font-size:13px;line-height:1.65;max-width:88%;}
.msg.ai{background:var(--bg3);border:1px solid var(--border);align-self:flex-start;}
.msg.user{background:rgba(24,119,242,.12);border:1px solid rgba(24,119,242,.25);align-self:flex-end;}
.msg-lbl{font-size:9px;color:var(--muted);font-family:var(--font-m);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;}
.ai-input-row{padding:11px 14px;border-top:1px solid var(--border);display:flex;gap:8px;}
.ai-input{flex:1;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;padding:8px 12px;color:var(--text);font-size:13px;outline:none;transition:border-color .15s;}
.ai-input:focus{border-color:var(--fb);}
.ai-input::placeholder{color:var(--muted);}
.btn{background:var(--fb);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-family:var(--font-d);font-weight:700;font-size:12px;cursor:pointer;transition:opacity .15s;}
.btn:hover{opacity:.88;}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border2);border-radius:8px;padding:5px 11px;font-size:11px;cursor:pointer;transition:all .15s;}
.btn-ghost:hover{color:var(--text);background:rgba(255,255,255,.04);}
.quick-btns{display:flex;gap:7px;flex-wrap:wrap;margin-top:9px;}

/* ML LIVE SEARCH */
.ml-search-bar{display:flex;gap:8px;margin-top:14px;}
.ml-search-input{flex:1;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;padding:9px 14px;color:var(--text);font-size:13px;outline:none;transition:border-color .15s;}
.ml-search-input:focus{border-color:#c8aa00;}
.btn-ml{background:#ffe600;color:#111;border:none;border-radius:8px;padding:9px 16px;font-family:var(--font-d);font-weight:700;font-size:12px;cursor:pointer;transition:opacity .15s;}
.btn-ml:hover{opacity:.85;}
.ml-result-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;display:flex;gap:12px;align-items:flex-start;transition:all .15s;cursor:pointer;}
.ml-result-card:hover{border-color:var(--border2);transform:translateY(-1px);}
.ml-thumb{width:56px;height:56px;object-fit:cover;border-radius:6px;background:var(--surface2);flex-shrink:0;}
.ml-title{font-size:12px;font-weight:500;line-height:1.4;}
.ml-price{font-family:var(--font-m);font-size:16px;font-weight:700;color:var(--green);margin-top:3px;}
.ml-meta{font-size:10px;color:var(--muted);margin-top:2px;}
.loading-dots{display:flex;gap:4px;padding:4px 0;}
.loading-dots span{width:6px;height:6px;background:var(--muted);border-radius:50%;animation:blink 1.2s infinite;}
.loading-dots span:nth-child(2){animation-delay:.2s;}
.loading-dots span:nth-child(3){animation-delay:.4s;}
@keyframes blink{0%,60%,100%{opacity:.2}30%{opacity:1}}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:100;align-items:center;justify-content:center;backdrop-filter:blur(6px);}
.modal-overlay.open{display:flex;}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--r2);width:720px;max-width:96vw;max-height:92vh;overflow-y:auto;}
.modal-head{padding:18px 22px 14px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;}
.modal-body{padding:18px 22px;}
.close-btn{cursor:pointer;background:none;border:none;color:var(--muted);font-size:22px;line-height:1;}
.close-btn:hover{color:var(--text);}

/* SIDEBAR CATS */
.sb-cats{padding:12px 14px;border-top:1px solid var(--border);font-size:11px;color:var(--muted);line-height:1.7;}
.sb-cats-title{font-family:var(--font-m);font-size:9px;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;color:var(--muted);}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* LARGE CAT SECTION */
.large-cat-header{display:flex;align-items:center;gap:10px;padding:14px 0 8px;}
.large-cat-icon{font-size:22px;}
.large-cat-title{font-family:var(--font-d);font-weight:700;font-size:16px;}
.large-cat-sub{font-size:11px;color:var(--muted);margin-top:1px;}
.mode-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:10px 0;}
.mode-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;text-align:center;}
.mode-card .mode-icon{font-size:18px;margin-bottom:4px;}
.mode-card .mode-name{font-size:11px;font-weight:600;font-family:var(--font-d);}
.mode-card .mode-desc{font-size:10px;color:var(--muted);margin-top:2px;line-height:1.4;}
.mode-card .mode-earn{font-size:11px;font-family:var(--font-m);margin-top:4px;}

/* ALERT BOX */
.alert-box{border-radius:var(--r);padding:10px 14px;font-size:12px;line-height:1.7;display:flex;gap:10px;align-items:flex-start;margin-top:14px;}
.alert-box.warn{background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.25);}
.alert-box.info{background:rgba(24,119,242,.06);border:1px solid rgba(24,119,242,.2);}
.alert-box.success{background:rgba(74,222,128,.06);border:1px solid rgba(74,222,128,.2);}
.alert-box.danger{background:rgba(248,113,113,.07);border:1px solid rgba(248,113,113,.25);}

@media(max-width:768px){
  .app{grid-template-columns:1fr;}
  .sidebar{display:none;}
  .metrics-row,.chart-grid,.chart-grid3{grid-template-columns:1fr;}
  .calc-grid{grid-template-columns:1fr;}
  .mode-grid{grid-template-columns:1fr 1fr;}
}
</style>
</head>
<body>
<div class="app">

<!-- ═══════════ SIDEBAR ═══════════ -->
<aside class="sidebar">
  <div class="logo">
    <div class="logo-name">MercadoIQ</div>
    <div class="logo-sub">TUCUMÁN · ARG</div>
    <div class="logo-v">v3 · API Mercado Libre Live</div>
  </div>
  <nav class="nav">
    <div class="nav-section">Productos pequeños</div>
    <div class="nav-item active" onclick="showView('demanda',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M1 12L5 7l3 3 3-4 3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Demanda Estacional <span class="nav-badge">★1</span>
    </div>
    <div class="nav-item" onclick="showView('competencia',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="6" r="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 14c0-3 2-5 5-5s5 2 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      Comparador Precios <span class="nav-badge">★2</span>
    </div>
    <div class="nav-item" onclick="showView('calculadora',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="12" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M5 5h6M5 8h6M5 11h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      Calculadora ROI <span class="nav-badge">★3</span>
    </div>
    <div class="nav-item" onclick="showView('proveedores',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M2 3h12l-1.5 7H3.5L2 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
      Dónde Comprar <span class="nav-badge">★4</span>
    </div>

    <div class="nav-section">Productos grandes</div>
    <div class="nav-item" onclick="showView('movilidad',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="5" cy="12" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.3"/><path d="M3 12H2V7l3-4h5l2 3h1.5a.5.5 0 01.5.5V10H10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      Movilidad Eléctrica
    </div>
    <div class="nav-item" onclick="showView('maquinaria',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.3"/><path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.22 3.22l1.42 1.42M11.36 11.36l1.42 1.42M3.22 12.78l1.42-1.42M11.36 4.64l1.42-1.42" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      Maquinaria & Generadores
    </div>
    <div class="nav-item" onclick="showView('inmuebles',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M1 14h14M2 14V7l6-5 6 5v7M6 14v-4h4v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Inmuebles
    </div>

    <div class="nav-section">Herramientas</div>
    <div class="nav-item" onclick="showView('ml-live',this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.3"/><path d="M9 9l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      Búsqueda ML en Vivo <span class="nav-badge live">LIVE</span>
