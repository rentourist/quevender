const hist=[];
async function mainChatSend(){
  const input=document.getElementById('main-chat-input');
  const msgs=document.getElementById('main-chat-msgs');
  const txt=input.value.trim();if(!txt)return;
  input.value='';addMsg(msgs,'user',txt);hist.push({role:'user',content:txt});
  const t=addTyping(msgs);
  const reply=await callAI(hist,SYSTEM);
  t.remove();addMsg(msgs,'ai',reply);hist.push({role:'assistant',content:reply});
}
