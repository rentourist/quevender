function addMsg(c,r,t){
  const d=document.createElement('div');
  d.innerHTML=`<div class="msg-lbl">${r==='ai'?'Asesor IA':'Vos'}</div><div class="msg ${r}">${t.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')}</div>`;
  c.appendChild(d);c.scrollTop=c.scrollHeight;
}
function addTyping(c){
  const d=document.createElement('div');d.id='typing-ind';
  d.innerHTML='<div class="msg ai"><div class="loading-dots"><span></span><span></span><span></span></div></div>';
  c.appendChild(d);c.scrollTop=c.scrollHeight;return d;
}
async function callAI(messages,system){
